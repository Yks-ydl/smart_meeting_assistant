# LLM API 配置（必需）
# 支持 OpenAI 兼容格式的 API（如 DeepSeek、通义千问等）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 可选：本地摘要模型配置
# SUMMARY_MODEL=fnlp/bart-base-chinese

# 摘要服务执行模式：
# local  = 启动本地 M2 摘要服务
# remote = 跳过本地 M2，由网关转发到远端（如 Colab）
SUMMARY_EXECUTION_MODE=local

# 当 SUMMARY_EXECUTION_MODE=remote 时，网关会把摘要请求发往该地址
SUMMARY_SERVICE_URL=http://127.0.0.1:8002/api/v1/summary/generate

# 远端摘要请求控制
SUMMARY_REMOTE_TIMEOUT_SEC=90
SUMMARY_REMOTE_RETRIES=1

# 远端摘要鉴权（如不需要可留空）
SUMMARY_REMOTE_AUTH_HEADER=Authorization
SUMMARY_REMOTE_AUTH_SCHEME=Bearer
SUMMARY_REMOTE_AUTH_TOKEN=

# Colab 侧服务参数（在 Colab 环境使用）
COLAB_SUMMARY_AUTH_ENABLED=true
COLAB_SUMMARY_AUTH_HEADER=Authorization
COLAB_SUMMARY_AUTH_SCHEME=Bearer
COLAB_SUMMARY_AUTH_TOKEN=
COLAB_SUMMARY_HOST=0.0.0.0
COLAB_SUMMARY_PORT=8002
SUMMARY_MAX_INPUT_TOKENS=1024
SUMMARY_MAX_OUTPUT_TOKENS=256
SUMMARY_DEVICE=auto

# 可选：用于 ngrok 建立公网隧道
NGROK_AUTHTOKEN=
